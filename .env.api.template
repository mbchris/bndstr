# bndstr API — environment variables
# Copy to .env.api (local dev) or configure in Coolify (production)

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
API_URL=http://localhost:3001

# ── Database (Coolify-managed PostgreSQL in production) ───────────────────────
# Local dev: use docker-compose.dev.yml
DATABASE_URL=postgresql://bndstr:bndstr_dev@localhost:5432/bndstr

# ── Auth (Better Auth) ────────────────────────────────────────────────────────
AUTH_SECRET=generate_a_random_secret_here_at_least_32_chars
CORS_ORIGINS=http://localhost:9000,https://app.bndstr.com

# ── OAuth providers ────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Stripe (Step 7) ────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=
# Legacy fallback (optional): treated like monthly if STRIPE_PRICE_PRO_MONTHLY is not set
STRIPE_PRICE_PRO=
# Google Play billing (Iteration 10)
GPLAY_PACKAGE_NAME=
GPLAY_PRODUCT_PRO_MONTHLY=
GPLAY_PRODUCT_PRO_YEARLY=
INTERNAL_ADMIN_TOKEN=

# ── Optional ──────────────────────────────────────────────────────────────────
GIT_REV=dev
