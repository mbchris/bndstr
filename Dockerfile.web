# ── Stage 1: Build ────────────────────────────────
FROM node:20-alpine AS build

WORKDIR /app

# Install pnpm
RUN corepack enable && corepack prepare pnpm@latest --activate

# Copy workspace root files
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml* ./

# Copy package.json for each workspace package
COPY packages/web/package.json packages/web/
COPY packages/shared/package.json packages/shared/

# Install dependencies
RUN pnpm install --filter @bndstr/web --filter @bndstr/shared --frozen-lockfile || pnpm install --filter @bndstr/web --filter @bndstr/shared

# Copy source
COPY packages/shared/ packages/shared/
COPY packages/web/ packages/web/

# Build-time env — API_URL is injected at build time for the SPA bundle
ARG API_URL=/api
ENV API_URL=${API_URL}

# Build Quasar SPA
RUN cd packages/web && pnpm run build

# ── Stage 2: Serve with Nginx ─────────────────────
FROM nginx:1.27-alpine AS production

# Remove default config
RUN rm /etc/nginx/conf.d/default.conf

# Copy custom Nginx config
COPY nginx.conf /etc/nginx/conf.d/bndstr.conf

# Copy built SPA from build stage
COPY --from=build /app/packages/web/dist/spa/ /usr/share/nginx/html/

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
