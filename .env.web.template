# bndstr Web (Quasar) — environment variables
# Copy to .env.web (local dev)

# The base URL of the API — in dev, proxied via Quasar devServer
API_URL=http://localhost:3001

# Enable extra login diagnostics in UI (true/false)
DEBUG_MODE=false

# Optional: build revision shown in Impress footer.
# If unset, web build resolves this from `git rev-parse --short HEAD`.
# GIT_REV=

# Native OAuth callback URL used inside Capacitor builds
MOBILE_CALLBACK_URL=org.capacitor.bndstr://localhost/login

# Optional: default adb target device for ./do build-apk
# ANDROID_DEVICE_ID=3B081JEHN00876
